<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>600266.xyz</title>
    <meta name="description" content="600266.xyz — A daring digital presence by Dharmanshu Kumar.">
    <meta name="author" content="Dharmanshu Kumar">
    <meta property="og:title" content="600266.xyz">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://600266.xyz">
    <link rel="canonical" href="https://600266.xyz">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #000000;
            --accent: #c9654a;
            --accent-light: #da8268;
            --accent-glow: rgba(201, 101, 74, 0.45);
            --text-primary: #f0f0f5;
            --text-muted: #4a4a5a;
            --term-green: #7fccab;
            --term-blue: #6eaad9;
            --font-display: 'Space Grotesk', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --font-body: 'Inter', sans-serif;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            width: 100%; height: 100%; overflow: hidden;
            background: var(--bg);
            font-family: var(--font-body);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
        }

        ::selection { background: rgba(201, 101, 74, 0.3); }

        /* ========== CANVAS ========== */
        canvas {
            position: fixed; top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 0;
        }

        /* ========== OVERLAYS ========== */
        .vignette {
            position: fixed; inset: 0; pointer-events: none; z-index: 1;
            background: radial-gradient(ellipse at 50% 45%, transparent 35%, rgba(3,3,6,0.7) 100%);
        }

        .noise {
            position: fixed; inset: 0; pointer-events: none; z-index: 2;
            opacity: 0.028;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            background-repeat: repeat;
            background-size: 512px 512px;
        }

        /* ========== TITLE ========== */
        .center {
            position: fixed; top: 50%; left: 50%;
            transform: translate(-50%, -52%);
            z-index: 10; text-align: center;
            pointer-events: none;
        }

        .main-title {
            font-family: var(--font-display);
            font-size: clamp(3rem, 11vw, 8.5rem);
            font-weight: 700;
            letter-spacing: -5px;
            color: var(--text-primary);
            line-height: 1;
            user-select: none;
            text-shadow:
                0 0 80px rgba(201, 101, 74, 0.15),
                0 0 200px rgba(201, 101, 74, 0.06);
            opacity: 0;
            animation: reveal 1.5s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
        }

        .main-title .dot { color: var(--accent); }

        @keyframes reveal {
            from { opacity: 0; transform: translateY(40px) scale(0.96); filter: blur(12px); }
            to { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
        }

        .typed-line {
            font-family: var(--font-mono);
            font-size: clamp(0.55rem, 1.2vw, 0.75rem);
            color: var(--text-muted);
            margin-top: 1.4rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            opacity: 0;
            animation: fadeIn 1s ease 1.6s forwards;
        }

        .typed-line .caret {
            display: inline-block; width: 2px; height: 1em;
            background: var(--accent); margin-left: 3px;
            vertical-align: text-bottom;
            animation: blink 1s step-end infinite;
        }

        @keyframes blink { 50% { opacity: 0; } }
        @keyframes fadeIn { to { opacity: 1; } }

        /* ========== PORTFOLIO BUTTON ========== */
        .cta-wrap {
            position: fixed; bottom: 10%; left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            opacity: 0;
            animation: fadeIn 1s ease 2s forwards;
        }

        .cta-btn {
            display: inline-flex; align-items: center; gap: 0.7rem;
            padding: 0.9rem 2.6rem;
            font-family: var(--font-display);
            font-size: 0.82rem; font-weight: 600;
            letter-spacing: 3px; text-transform: uppercase;
            color: var(--accent-light);
            background: rgba(201, 101, 74, 0.05);
            border: 1px solid rgba(201, 101, 74, 0.18);
            border-radius: 60px;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .cta-btn:hover {
            background: rgba(201, 101, 74, 0.14);
            border-color: rgba(201, 101, 74, 0.5);
            color: #fff;
            box-shadow: 0 0 60px rgba(201, 101, 74, 0.15), 0 10px 50px rgba(0,0,0,0.4);
            transform: translateY(-3px);
        }

        .cta-btn:active { transform: translateY(0); }

        .cta-arrow {
            transition: transform 0.3s ease; opacity: 0.6;
        }

        .cta-btn:hover .cta-arrow {
            transform: translateX(5px); opacity: 1;
        }

        /* ========== COPYRIGHT ========== */
        .copyright {
            position: fixed;
            bottom: 1.2rem; right: 1.5rem;
            z-index: 10;
            font-family: var(--font-mono);
            font-size: 0.5rem;
            color: rgba(255,255,255,0.12);
            letter-spacing: 1.5px;
            pointer-events: none;
            opacity: 0;
            animation: fadeIn 0.8s ease 2.5s forwards;
        }

        /* ========== HINT ========== */
        .hint {
            position: fixed; bottom: 4%; left: 50%;
            transform: translateX(-50%);
            font-family: var(--font-mono);
            font-size: 0.5rem;
            color: rgba(255,255,255,0.1);
            letter-spacing: 3px;
            text-transform: uppercase;
            z-index: 10;
            pointer-events: none;
            opacity: 0;
            animation: fadeIn 1s ease 3.5s forwards, floatY 4s ease-in-out infinite 3.5s;
        }

        @keyframes floatY {
            0%, 100% { transform: translateX(-50%) translateY(0); }
            50% { transform: translateX(-50%) translateY(-5px); }
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 600px) {
            .main-title { letter-spacing: -2px; }
            .hud-bl { display: none; }
            .cta-btn { padding: 0.75rem 2rem; font-size: 0.72rem; letter-spacing: 2px; }
        }
    </style>
</head>

<body>
    <canvas id="c"></canvas>
    <div class="vignette"></div>
    <div class="noise"></div>

    <!-- Copyright -->
    <div class="copyright">© 600266.xyz</div>

    <!-- Title -->
    <div class="center">
        <h1 class="main-title">600266<span class="dot">.</span>xyz</h1>
        <p class="typed-line"><span id="typed"></span><span class="caret"></span></p>
    </div>

    <!-- CTA -->
    <div class="cta-wrap">
        <a href="https://portfolio.600266.xyz" class="cta-btn" id="cta">
            <span>Portfolio</span>
            <svg class="cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
        </a>
    </div>

    <!-- Hint -->
    <div class="hint">move · click · hold · explore</div>

    <script>
    (() => {
        // =====================
        //  SETUP
        // =====================
        const canvas = document.getElementById('c');
        const ctx = canvas.getContext('2d');
        let W, H, cx, cy;

        function resize() {
            W = canvas.width = window.innerWidth;
            H = canvas.height = window.innerHeight;
            cx = W / 2;
            cy = H / 2;
        }
        resize();
        window.addEventListener('resize', resize);

        // =====================
        //  MOUSE STATE
        // =====================
        let mx = cx, my = cy, mouseIn = false, mouseDown = false;
        let mouseVx = 0, mouseVy = 0, pmx = cx, pmy = cy;

        document.addEventListener('mousemove', e => {
            mx = e.clientX; my = e.clientY;
            mouseIn = true;
        });
        document.addEventListener('mouseleave', () => { mouseIn = false; });
        document.addEventListener('mousedown', () => { mouseDown = true; });
        document.addEventListener('mouseup', () => { mouseDown = false; });

        // Touch support
        document.addEventListener('touchmove', e => {
            e.preventDefault();
            const t = e.touches[0];
            mx = t.clientX; my = t.clientY;
            mouseIn = true;
        }, { passive: false });
        document.addEventListener('touchstart', e => {
            const t = e.touches[0];
            mx = t.clientX; my = t.clientY;
            mouseIn = true;
            mouseDown = true;
        });
        document.addEventListener('touchend', () => { mouseDown = false; });

        // Click → pulse
        document.addEventListener('click', e => {
            createPulse(e.clientX, e.clientY);
        });



        // =====================
        //  PARTICLES
        // =====================
        const NODE_COUNT = 100;
        const CONNECT_DIST = 160;
        const MOUSE_ATTRACT_R = 250;
        const MOUSE_REPEL_R = 60;
        const nodes = [];

        class Node {
            constructor() {
                this.x = Math.random() * W;
                this.y = Math.random() * H;
                this.vx = (Math.random() - 0.5) * 0.4;
                this.vy = (Math.random() - 0.5) * 0.4;
                this.r = Math.random() * 1.8 + 0.6;
                this.baseR = this.r;
                this.alpha = Math.random() * 0.3 + 0.2;
                this.baseAlpha = this.alpha;
                this.energy = 0;
                this.phase = Math.random() * Math.PI * 2;
            }

            getColor(a) {
                return `rgba(201,101,74,${a})`;
            }

            update() {
                this.phase += 0.015;

                // Natural drift
                this.vx += (Math.random() - 0.5) * 0.02;
                this.vy += (Math.random() - 0.5) * 0.02;

                // Mouse interaction
                if (mouseIn) {
                    const dx = mx - this.x;
                    const dy = my - this.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    if (dist < MOUSE_ATTRACT_R && dist > MOUSE_REPEL_R) {
                        // Attract gently
                        const strength = mouseDown ? 0.06 : 0.012;
                        const force = (1 - (dist - MOUSE_REPEL_R) / (MOUSE_ATTRACT_R - MOUSE_REPEL_R)) * strength;
                        this.vx += (dx / dist) * force;
                        this.vy += (dy / dist) * force;
                        this.energy = Math.min(1, this.energy + 0.03);
                    } else if (dist < MOUSE_REPEL_R) {
                        // Repel close ones (so they orbit)
                        const force = (1 - dist / MOUSE_REPEL_R) * 0.15;
                        this.vx -= (dx / dist) * force;
                        this.vy -= (dy / dist) * force;
                        this.energy = Math.min(1, this.energy + 0.06);
                    }
                }

                // Damping
                this.vx *= 0.985;
                this.vy *= 0.985;

                // Clamp speed
                const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
                if (speed > 3) {
                    this.vx = (this.vx / speed) * 3;
                    this.vy = (this.vy / speed) * 3;
                }

                this.x += this.vx;
                this.y += this.vy;

                // Soft edge bounce
                const margin = 20;
                if (this.x < margin) { this.x = margin; this.vx = Math.abs(this.vx) * 0.5; }
                if (this.x > W - margin) { this.x = W - margin; this.vx = -Math.abs(this.vx) * 0.5; }
                if (this.y < margin) { this.y = margin; this.vy = Math.abs(this.vy) * 0.5; }
                if (this.y > H - margin) { this.y = H - margin; this.vy = -Math.abs(this.vy) * 0.5; }

                // Energy decay
                this.energy *= 0.97;

                // Animated radius & alpha
                const pulse = Math.sin(this.phase) * 0.3;
                this.r = this.baseR + this.energy * 2 + pulse * 0.3;
                this.alpha = this.baseAlpha + this.energy * 0.5;
            }

            draw() {
                const a = Math.min(1, this.alpha);

                // Outer glow when energized
                if (this.energy > 0.1) {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.r + this.energy * 8, 0, Math.PI * 2);
                    ctx.fillStyle = this.getColor(this.energy * 0.15);
                    ctx.fill();
                }

                // Core
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
                ctx.fillStyle = this.getColor(a);
                ctx.fill();
            }
        }

        for (let i = 0; i < NODE_COUNT; i++) nodes.push(new Node());

        // =====================
        //  PULSES (click waves)
        // =====================
        const pulses = [];

        function createPulse(x, y) {
            pulses.push({
                x, y,
                radius: 0,
                maxRadius: 300,
                speed: 6,
                alpha: 0.8,
                color: '201,101,74'
            });
            // Also push nodes outward
            nodes.forEach(n => {
                const dx = n.x - x;
                const dy = n.y - y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 300 && dist > 0) {
                    const force = (1 - dist / 300) * 3;
                    n.vx += (dx / dist) * force;
                    n.vy += (dy / dist) * force;
                    n.energy = Math.min(1, n.energy + (1 - dist / 300));
                }
            });
        }

        function updatePulses() {
            for (let i = pulses.length - 1; i >= 0; i--) {
                const p = pulses[i];
                p.radius += p.speed;
                p.alpha = (1 - p.radius / p.maxRadius) * 0.5;

                if (p.radius >= p.maxRadius) {
                    pulses.splice(i, 1);
                    continue;
                }

                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                ctx.strokeStyle = `rgba(${p.color}, ${p.alpha})`;
                ctx.lineWidth = 1.5;
                ctx.stroke();

                // Inner thinner ring
                if (p.radius > 20) {
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.radius * 0.7, 0, Math.PI * 2);
                    ctx.strokeStyle = `rgba(${p.color}, ${p.alpha * 0.3})`;
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            }
        }

        // =====================
        //  CONNECTIONS
        // =====================
        function drawConnections() {
            let linkCount = 0;

            for (let i = 0; i < nodes.length; i++) {
                for (let j = i + 1; j < nodes.length; j++) {
                    const a = nodes[i], b = nodes[j];
                    const dx = a.x - b.x;
                    const dy = a.y - b.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    if (dist < CONNECT_DIST) {
                        linkCount++;
                        const t = 1 - dist / CONNECT_DIST;
                        let alpha = t * 0.12;

                        // Brighter near mouse
                        if (mouseIn) {
                            const midX = (a.x + b.x) / 2;
                            const midY = (a.y + b.y) / 2;
                            const mDist = Math.sqrt((midX - mx) ** 2 + (midY - my) ** 2);
                            if (mDist < MOUSE_ATTRACT_R) {
                                const boost = (1 - mDist / MOUSE_ATTRACT_R);
                                alpha += boost * 0.2;
                            }
                        }

                        // Gradient line color based on energy of connected nodes
                        const energy = (a.energy + b.energy) / 2;
                        if (energy > 0.1) {
                            ctx.strokeStyle = `rgba(201, 101, 74, ${alpha + energy * 0.3})`;
                        } else {
                            ctx.strokeStyle = `rgba(200, 200, 220, ${alpha})`;
                        }

                        ctx.lineWidth = t * 0.8 + 0.2;
                        ctx.beginPath();
                        ctx.moveTo(a.x, a.y);
                        ctx.lineTo(b.x, b.y);
                        ctx.stroke();
                    }
                }
            }
            return linkCount;
        }

        // =====================
        //  MOUSE FIELD LINES
        // =====================
        function drawMouseField() {
            if (!mouseIn) return;

            // Draw subtle radial ring
            const fieldR = mouseDown ? MOUSE_ATTRACT_R * 1.2 : MOUSE_ATTRACT_R;
            const fieldAlpha = mouseDown ? 0.06 : 0.025;

            ctx.beginPath();
            ctx.arc(mx, my, fieldR, 0, Math.PI * 2);
            ctx.strokeStyle = `rgba(201, 101, 74, ${fieldAlpha})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();

            // Inner ring
            ctx.beginPath();
            ctx.arc(mx, my, MOUSE_REPEL_R, 0, Math.PI * 2);
            ctx.strokeStyle = `rgba(201, 101, 74, ${fieldAlpha * 1.5})`;
            ctx.lineWidth = 0.5;
            ctx.setLineDash([3, 5]);
            ctx.stroke();
            ctx.setLineDash([]);

            // Draw lines from mouse to nearby nodes
            nodes.forEach(n => {
                const dx = n.x - mx;
                const dy = n.y - my;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < MOUSE_ATTRACT_R * 0.6) {
                    const a = (1 - dist / (MOUSE_ATTRACT_R * 0.6)) * (mouseDown ? 0.2 : 0.08);
                    ctx.strokeStyle = `rgba(201, 101, 74, ${a})`;
                    ctx.lineWidth = 0.6;
                    ctx.beginPath();
                    ctx.moveTo(mx, my);
                    ctx.lineTo(n.x, n.y);
                    ctx.stroke();
                }
            });

            // Cursor dot
            ctx.beginPath();
            ctx.arc(mx, my, mouseDown ? 4 : 2.5, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(201, 101, 74, ${mouseDown ? 0.8 : 0.4})`;
            ctx.fill();
        }

        // =====================
        //  BACKGROUND GEOMETRY
        // =====================
        const geos = [];

        class Geo {
            constructor() {
                this.x = Math.random() * W;
                this.y = Math.random() * H;
                this.size = Math.random() * 50 + 25;
                this.rotation = Math.random() * Math.PI * 2;
                this.rotV = (Math.random() - 0.5) * 0.003;
                this.vx = (Math.random() - 0.5) * 0.15;
                this.vy = (Math.random() - 0.5) * 0.15;
                this.sides = [3, 4, 5, 6][Math.floor(Math.random() * 4)];
                this.alpha = Math.random() * 0.025 + 0.01;
            }

            getColor() {
                return `rgba(201,101,74,${this.alpha})`;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;
                this.rotation += this.rotV;

                // React to mouse
                if (mouseIn) {
                    const dx = mx - this.x, dy = my - this.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 250) {
                        this.rotV += (Math.random() - 0.5) * 0.0005;
                    }
                }

                // Wrap
                if (this.x < -100) this.x = W + 100;
                if (this.x > W + 100) this.x = -100;
                if (this.y < -100) this.y = H + 100;
                if (this.y > H + 100) this.y = -100;
            }

            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate(this.rotation);
                ctx.strokeStyle = this.getColor();
                ctx.lineWidth = 0.8;
                ctx.beginPath();
                for (let i = 0; i < this.sides; i++) {
                    const angle = (Math.PI * 2 / this.sides) * i - Math.PI / 2;
                    ctx[i === 0 ? 'moveTo' : 'lineTo'](
                        Math.cos(angle) * this.size,
                        Math.sin(angle) * this.size
                    );
                }
                ctx.closePath();
                ctx.stroke();
                ctx.restore();
            }
        }

        for (let i = 0; i < 7; i++) geos.push(new Geo());

        // =====================
        //  AMBIENT STARS
        // =====================
        const stars = [];
        for (let i = 0; i < 60; i++) {
            stars.push({
                x: Math.random() * W,
                y: Math.random() * H,
                r: Math.random() * 1 + 0.2,
                phase: Math.random() * Math.PI * 2,
                speed: Math.random() * 0.008 + 0.003
            });
        }

        function drawStars() {
            for (const s of stars) {
                s.phase += s.speed;
                const a = 0.1 + Math.sin(s.phase) * 0.07;
                ctx.beginPath();
                ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255,255,255,${a})`;
                ctx.fill();
            }
        }

        // =====================
        //  MAIN LOOP
        // =====================
        function frame() {
            ctx.clearRect(0, 0, W, H);

            // Mouse velocity
            mouseVx = mx - pmx;
            mouseVy = my - pmy;
            pmx = mx; pmy = my;

            // Layers
            drawStars();
            geos.forEach(g => { g.update(); g.draw(); });

            drawConnections();
            drawMouseField();
            updatePulses();

            // Nodes
            nodes.forEach(n => { n.update(); n.draw(); });

            requestAnimationFrame(frame);
        }
        frame();

        // =====================
        //  TYPING
        // =====================
        const phrases = ['innocous', '600266'];
        const typedEl = document.getElementById('typed');
        let pI = 0, cI = 0, del = false, spd = 85;

        function typeLoop() {
            const cur = phrases[pI];
            if (del) { typedEl.textContent = cur.substring(0, --cI); spd = 30; }
            else { typedEl.textContent = cur.substring(0, ++cI); spd = 85; }

            if (!del && cI === cur.length) { spd = 5000; del = true; }
            else if (del && cI === 0) { del = false; pI = (pI + 1) % phrases.length; spd = 500; }

            setTimeout(typeLoop, spd);
        }
        setTimeout(typeLoop, 2200);

        // =====================
        //  RESIZE HANDLER
        // =====================
        window.addEventListener('resize', () => {
            resize();
            // Re-scatter stars
            stars.forEach(s => { s.x = Math.random() * W; s.y = Math.random() * H; });
        });

    })();
    </script>
</body>

</html>
